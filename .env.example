# Copy this file to .env and adjust as needed. .env is gitignored.

# UI/CLI language: en (default) or zh
LUC_LANG=en

# LLM endpoint (OpenAI-compatible /chat/completions API)
LUC_LLM_BASE_URL=http://localhost:8003/v1
LUC_LLM_MODEL=qwen3.6-27b-awq-int4
LUC_LLM_API_KEY=none

# Embedding model override (defaults depend on LUC_LANG: bge-small-zh for zh, multilingual MiniLM otherwise)
# LUC_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# HTTP API auth key — if set, all API requests must include X-API-Key header
# Leave empty to disable auth (only do this if the API is not exposed externally)
# LUC_API_KEY=your-secret-key-here

# API server port (default 8080)
# LUC_API_PORT=8080

# Optional: where cron_runner.py should send you an alert if a messaging
# channel or the LLM endpoint goes down (checked every 15 min via api.py's
# /status) — same "platform:id" format as a scheduled task's notify_channel.
# Without this set, health-check alerting is entirely off (opt-in).
# LUC_ADMIN_NOTIFY=wecom:your_wecom_user_id
